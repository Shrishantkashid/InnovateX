# SafeGuard AI Engine — Environment Variables
# Copy this to .env and fill in your values

# ---- OpenAI (for digest/coach) ----
OPENAI_API_KEY=sk-xxxx

# ---- Groq (for route risk) ----
GROQ_API_KEY=gsk_xxxx

# ---- Supabase ----
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ---- Google Places ----
GOOGLE_PLACES_API_KEY=AIzaxxxx

# ---- Alert Thresholds (Module 1 — Women) ----
M1_AUDIO_THRESHOLD=0.70
M1_MOTION_G_THRESHOLD=2.5
M1_CONFIRM_WINDOW_SEC=10

# ---- Alert Thresholds (Module 2 — Child) ----
M2_AUDIO_THRESHOLD=0.55
M2_MOTION_G_THRESHOLD=2.0
M2_CONFIRM_WINDOW_SEC=5
