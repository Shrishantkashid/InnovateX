# ---- SUPABASE ----
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...          # server-side only, never expose to client

# ---- TWILIO ----
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_PHONE_NUMBER=+1234567890      # SMS sender
TWILIO_WHATSAPP_NUMBER=+1415523886   # WhatsApp sandbox number

# ---- OPENAI ----
OPENAI_API_KEY=sk-xxxx

# ---- GOOGLE ----
GOOGLE_PLACES_API_KEY=AIzaxxxx

# ---- NEXTDNS (Module 3) ----
NEXTDNS_API_KEY=xxxx
NEXTDNS_PROFILE_ID=xxxx

# ---- APP CONFIG ----
API_BASE_URL=http://localhost:8000   # change to Railway URL in prod
JWT_SECRET=your-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440              # 24 hours

# ---- ALERT THRESHOLDS ----
M1_AUDIO_THRESHOLD=0.70
M2_AUDIO_THRESHOLD=0.55
M1_CONFIRM_WINDOW_SEC=10
M2_CONFIRM_WINDOW_SEC=5
M1_MOTION_G_THRESHOLD=2.5
M2_MOTION_G_THRESHOLD=2.0

# ---- GUARDIAN NETWORK ----
GUARDIAN_RADIUS_M=500
GUARDIAN_COOLDOWN_MIN=30             # prevent duplicate pings

# ---- CRON SCHEDULE ----
DIGEST_CRON=0 8 * * 1               # 8am every Monday
HEATMAP_CRON=0 2 * * *              # 2am daily
